<?xml version="1.0" encoding="UTF-8"?>
<permissions>

    <permission name="quiqqer.oauth-server.manage_clients" type="bool">
        <defaultvalue>0</defaultvalue>
        <rootPermission>1</rootPermission>
        <everyonePermission>0</everyonePermission>
    </permission>

    <permission name="quiqqer.oauth-server.create_permanent_access_token_for_own_user" type="bool">
        <defaultvalue>0</defaultvalue>
        <rootPermission>1</rootPermission>
        <everyonePermission>0</everyonePermission>
    </permission>

    <permission name="quiqqer.oauth-server.max_number_of_permanent_access_tokens" type="int">
        <defaultvalue>1</defaultvalue>
        <rootPermission>-1</rootPermission>
        <everyonePermission>1</everyonePermission>
    </permission>

</permissions>